@article{mahore2026crisis,
  title     = {Edge-Deployable Crisis Tweet Summarization Using Lightweight Transformer Models},
  author    = {Mahore, Tushar},
  journal   = {Manuscript in preparation},
  year      = {2026},
  abstract  = {We present an edge-deployable NLP pipeline for real-time disaster situation
               summarization from social media, designed to operate without internet connectivity.
               We evaluate six abstractive models across five metrics and identify DistilBART
               as the optimal edge model (353 MB, BERTScore ~0.82, Flesch readability 60.7),
               while Flan-T5 with ChromaDB RAG achieves the highest quality score (BERTScore 0.8403)
               for connected environments.},
  keywords  = {NLP, summarization, crisis informatics, edge computing, disaster response}
}
